# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Database
DATABASE_URL=postgres://postgres:postgres@db:5432/prepaidgasmeter

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# M-Pesa Daraja (Sandbox)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/v1/payments/mpesa/callback/

# Stron Vending API
STRON_API_URL=http://www.server-newv.stronpower.com/api
STRON_DIRECT_API_URL=http://www.server-newv.stronpower.com/api
STRON_COMPANY_NAME=your-company-name
STRON_USERNAME=your-stron-username
STRON_PASSWORD=your-stron-password
STRON_VEND_BY_UNIT=False
STRON_USE_DIRECT_VENDING=False

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@prepaidgasmeter.co.ke

# SMS
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=PREPAID

# Business Rules
MIN_PURCHASE_AMOUNT=50
MAX_PURCHASE_AMOUNT=50000
